# Server
PORT=5000

# MongoDB connection string — local or MongoDB Atlas
MONGO_URI=mongodb://localhost:27017/meridian_college

# Long, random secret used to sign JWTs — never commit a real secret
JWT_SECRET=replace_with_a_long_random_secret

# Used by the /api/student/ask-ai endpoint to call the Claude API server-side
ANTHROPIC_API_KEY=your_anthropic_api_key_here
